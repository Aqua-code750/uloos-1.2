ENTRY(_start)

SECTIONS {
    . = 0x800000; /* link address at 8MB to completely bypass bootloader page maps */

    .text :
    {
        *(.text .text.*)
    }

    .rodata :
    {
        *(.rodata .rodata.*)
    }

    .data :
    {
        *(.data .data.*)
    }

    .bss :
    {
        *(.bss .bss.*)
    }
}
